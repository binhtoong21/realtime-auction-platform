# Môi trường chạy Frontend

# Đường dẫn URL đầy đủ tới Backend để kết nối Socket.IO
# Socket.IO không thể dùng proxy của Vite để thiết lập WebSocket connection an toàn
VITE_API_URL=http://localhost:3000

# Khóa public của Stripe dùng cho luồng Add Card / Join Auction
# Lấy từ https://dashboard.stripe.com/test/apikeys
VITE_STRIPE_PUBLIC_KEY=pk_test_...
